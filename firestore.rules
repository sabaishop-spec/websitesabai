rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'sonnt.credit@gmail.com' || 
        request.auth.token.email == 'sabaishop7979@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/settings/admin) && request.auth.uid == get(/databases/$(database)/documents/settings/admin).data.uid)
      );
    }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && !exists(/databases/$(database)/documents/settings/admin));
    }
    
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin() || request.auth.uid == uid;
    }
    
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin(); 
    }
    match /blogPosts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /blogCategories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /faqs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
