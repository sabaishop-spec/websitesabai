{
  "entities": {
    "ProductCategory": {
      "title": "ProductCategory",
      "description": "Category of products containing a list of products",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "heroImage": { "type": "string" },
        "products": {
          "type": "array",
          "description": "Embedded products"
        }
      },
      "required": ["title"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog post",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["title", "content"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently asked question",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" }
      },
      "required": ["question", "answer"]
    }
  },
  "firestore": {
    "products": {
      "schema": { "$ref": "ProductCategory" },
      "description": "Categories and nested products"
    },
    "blogPosts": {
      "schema": { "$ref": "BlogPost" },
      "description": "Blog Posts"
    },
    "faqs": {
      "schema": { "$ref": "FAQ" },
      "description": "FAQs"
    }
  }
}
